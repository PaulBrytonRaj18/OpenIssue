# ============================================================
# IssueCompass — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- GitHub OAuth App ---
# Create at: https://github.com/settings/applications/new
# Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# --- GitHub Personal Access Token ---
# Used by backend for higher API rate limits (60 -> 5000 req/hr)
# Create at: https://github.com/settings/tokens
# Scopes needed: public_repo, read:user
GITHUB_TOKEN=your_github_personal_access_token

# --- NextAuth (Frontend) ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_super_secret_random_string_change_this

# --- Database ---
# Local: postgresql://issuecompass:issuecompass@localhost:5432/issuecompass
# Supabase (direct): postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
# Supabase (PgBouncer — recommended for serverless): same but port 6543
# NOTE: Do NOT include +asyncpg here; the backend adds it automatically
DATABASE_URL=postgresql://issuecompass:issuecompass@localhost:5432/issuecompass

# --- Redis (caching + rate limiting + background workers) ---
REDIS_URL=redis://localhost:6379
# Optional: tune connection pool for production
# REDIS_SOCKET_TIMEOUT=3
# REDIS_SOCKET_CONNECT_TIMEOUT=3
# REDIS_RETRY_ON_TIMEOUT=true
# REDIS_MAX_CONNECTIONS=20
# REDIS_PREFIX=ic:

# --- Backend API URL (used by frontend) ---
# Do NOT add a trailing slash. Examples:
#   http://localhost:8000
#   https://issuecompass-api.vercel.app
#   "" (empty = same-origin /api/v1 — works when frontend+backend share a domain)
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Backend JWT Secret ---
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_this_in_production_use_random_string

# --- Groq AI for enhanced skill extraction, query parsing, and recommendations ---
# Get your free API key at: https://console.groq.com/keys
# GROQ_API_KEY=gsk_your_groq_api_key
# GROQ_MODEL=llama-3.3-70b-versatile
# AI_ENABLED=true

# Jina AI (embeddings)
# JINA_API_KEY=jina_your_jina_api_key
# JINA_EMBED_MODEL=jina-embeddings-v3
# EMBEDDINGS_ENABLED=true

# --- CORS ---
# Comma-separated list of allowed origins for cross-origin requests.
# ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend-url

# --- Metrics ---
# Optional API key to protect the /metrics endpoint.
# METRICS_API_KEY=your_random_metrics_key

# --- Cookie Security ---
# Set to true in production (requires HTTPS). False for local dev (HTTP).
# COOKIE_SECURE=false
