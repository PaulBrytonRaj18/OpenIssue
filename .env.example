# ============================================================
# OpenIssue — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- GitHub OAuth App ---
# Create at: https://github.com/settings/applications/new
# Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# --- GitHub Personal Access Token ---
# Used by backend for higher API rate limits (60 -> 5000 req/hr)
# Create at: https://github.com/settings/tokens
# Scopes needed: public_repo, read:user
GITHUB_TOKEN=your_github_personal_access_token

# --- NextAuth (Frontend) ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_super_secret_random_string_change_this

# --- Database ---
# Local: postgresql://openissue:openissue@localhost:5432/openissue
# Supabase (direct): postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
# Supabase (PgBouncer — recommended for serverless): same but port 6543
# NOTE: Do NOT include +asyncpg here; the backend adds it automatically
DATABASE_URL=postgresql://openissue:openissue@localhost:5432/openissue

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Backend API URL (used by frontend) ---
# Do NOT add a trailing slash. Examples:
#   http://localhost:8000
#   https://openissue-api.vercel.app
#   "" (empty = same-origin /api/v1 — works when frontend+backend share a domain)
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Backend JWT Secret ---
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_this_in_production_use_random_string

# --- Optional: OpenAI for enhanced skill extraction ---
# OPENAI_API_KEY=your_openai_api_key

# --- CORS (Cloud Run) ---
# Set this to the frontend's Cloud Run URL so the backend allows cross-origin requests.
# Example: https://openissue-frontend-xxxxx-uc.a.run.app
# FRONTEND_URL=https://your-frontend-cloud-run-url

# ============================================================
# Cloud Run Deployment — set these in your Cloud Run service
# ============================================================
#
# Backend service env vars:
#   DATABASE_URL, SECRET_KEY, GITHUB_TOKEN, FRONTEND_URL, REDIS_URL
#   GITHUB_CLIENT_ID, GITHUB_CLIENT_SECRET (via Secret Manager)
#
# Frontend service env vars:
#   NEXT_PUBLIC_API_URL=https://your-backend-cloud-run-url
#   NEXTAUTH_URL=https://your-frontend-cloud-run-url
#   NEXTAUTH_SECRET, GITHUB_CLIENT_ID, GITHUB_CLIENT_SECRET (via Secret Manager)
#
# Build args (for frontend Docker image):
#   NEXT_PUBLIC_API_URL  (baked into JS bundle at build time)
#
# Supabase note:
#   For serverless (Cloud Run), use port 6543 (PgBouncer transaction pooler)
#   instead of 5432 (direct): postgresql://postgres:pass@db.ref.supabase.co:6543/postgres
#   Do NOT include +asyncpg in the URL — the backend adds it automatically
